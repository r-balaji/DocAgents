<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Grants access to the AI Doc Coverage Review and AI Doc Splitter features.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>AI Doc Access</label>
    <license>Salesforce</license>

    <classAccesses>
        <apexClass>AIDocCoverageCheck</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AIDocSplitFileRow</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AIDocWriteEmailTemplate</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AIDocMergeJsonItems</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AIDocReviewResultStore</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AIDocReviewPromptRouter</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SplitJobService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ClassifyQueueable</apexClass>
