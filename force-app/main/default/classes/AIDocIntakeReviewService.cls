/**
 * Headless review orchestration for portal/API document intake.
 */
public with sharing class AIDocIntakeReviewService {
    private static final String REVIEW_FLOW_NAME = 'AIDocVerifyOneFile';
    private static final String DEFAULT_REVIEW_JSON =
        '{"items":[{"documentName":"AI Document Review","severity":"success","status":"ACCEPTABLE","summary":"Test review completed.","detail":"Generated by test stub."}]}';
    private static final String REVIEW_FAILED_JSON =
        '{"items":[{"documentName":"Review Failed","severity":"error","status":"UNREADABLE","summary":"AI review could not complete for this file.","detail":"The review prompt or file lookup failed before producing a response. Please retry the review or replace the document."}]}';

    @TestVisible
    static String testStubReviewJson;

    @TestVisible
    static Boolean testAutoReviewFallbackCategory;

    /**
     * Starts the headless review batch for intake jobs that have finished category mapping.
     * @param intakeJobIds Intake jobs whose mapped files should be reviewed.
     */
    public static void enqueueReview(Set<Id> intakeJobIds) {
        Set<Id> normalizedJobIds = normalizeIds(intakeJobIds);
        if (normalizedJobIds.isEmpty()) {
            return;
        }
        Database.executeBatch(new AIDocIntakeReviewBatch(new List<Id>(normalizedJobIds)), 1);
    }

    /**
     * Builds the existing AI Document Review row contract for unreviewed files on the intake applications.
     * @param intakeJobIds Intake jobs to inspect.
     * @return Encoded review rows from AIDocCoverageCheck.
     */
    public static List<String> buildReviewRows(Set<Id> intakeJobIds) {
        Map<Id, Boolean> includeFallbackByApplicationId =
            loadFallbackReviewSettingByApplicationId(intakeJobIds);
        List<String> rows = new List<String>();
        for (Id applicationId : includeFallbackByApplicationId.keySet()) {
            AIDocCoverageCheck.Response coverage = loadCoverage(
                applicationId,
                includeFallbackByApplicationId.get(applicationId) == true
            );
            if (coverage == null || coverage.isSuccess != true) {
                throw new SplitJobException(coverage == null
                    ? 'AI review coverage check failed.'
                    : coverage.errorMessage);
            }
            if (coverage.encodedRows != null) {
                rows.addAll(coverage.encodedRows);
            }
        }
        return rows;
    }

    /**
     * Reviews and stores the supplied encoded rows.
     * @param encodedRows Rows from AIDocCoverageCheck.
     */
    public static void reviewEncodedRows(List<String> encodedRows) {
        if (encodedRows == null || encodedRows.isEmpty()) {
            return;
        }

        List<AIDocReviewResultStore.Request> saveRequests = new List<AIDocReviewResultStore.Request>();
        for (String encodedRow : encodedRows) {
            ReviewRow row = decodeRow(encodedRow);
            if (!row.isReviewable()) {
                continue;
            }
            ReviewPayload payload = runReviewFlow(row);
            AIDocReviewResultStore.Request saveRequest = new AIDocReviewResultStore.Request();
            saveRequest.documentCategoryId = row.documentCategoryId;
            saveRequest.fileContentDocumentId = row.fileContentDocumentId;
            saveRequest.classificationJson = payload.classificationJson;
            saveRequest.sanityJson = payload.sanityJson;
            saveRequests.add(saveRequest);
        }

        if (saveRequests.isEmpty()) {
            return;
        }

        List<AIDocReviewResultStore.Response> saveResponses = AIDocReviewResultStore.execute(saveRequests);
        List<String> errors = new List<String>();
        for (AIDocReviewResultStore.Response response : saveResponses) {
            if (response != null && response.isSuccess == true) {
                continue;
            }
            errors.add(response == null || String.isBlank(response.errorMessage)
                ? 'AI review result could not be stored.'
                : response.errorMessage);
        }
        if (!errors.isEmpty()) {
            throw new SplitJobException(String.join(errors, ' | '));
        }
    }

    private static Map<Id, Boolean> loadFallbackReviewSettingByApplicationId(Set<Id> intakeJobIds) {
        Map<Id, Boolean> includeFallbackByApplicationId = new Map<Id, Boolean>();
        Set<Id> normalizedJobIds = normalizeIds(intakeJobIds);
        if (normalizedJobIds.isEmpty()) {
            return includeFallbackByApplicationId;
        }

        for (Document_Intake_Job__c job : [
            SELECT Id, Application__c, Source__c
            FROM Document_Intake_Job__c
            WHERE Id IN :normalizedJobIds
            WITH USER_MODE
        ]) {
            if (job.Application__c == null) {
                continue;
            }
            Boolean includeFallback = includeFallbackByApplicationId.get(job.Application__c) == true
                || shouldAutoReviewFallbackCategory(job.Source__c);
            includeFallbackByApplicationId.put(job.Application__c, includeFallback);
        }
        return includeFallbackByApplicationId;
    }

    private static AIDocCoverageCheck.Response loadCoverage(
        Id applicationId,
        Boolean includeFallbackCategory
    ) {
        AIDocCoverageCheck.Request req = new AIDocCoverageCheck.Request();
        req.applicationId = applicationId;
        req.includeFallbackCategory = includeFallbackCategory;
        List<AIDocCoverageCheck.Response> responses =
            AIDocCoverageCheck.execute(new List<AIDocCoverageCheck.Request>{ req });
        return responses.isEmpty() ? null : responses[0];
    }

    /**
     * Returns whether automated intake should review the configured fallback category.
     * @param source Intake source used to select an active configuration.
     * @return True when the matching configuration enables fallback-category review.
     */
    public static Boolean shouldAutoReviewFallbackCategory(String source) {
        if (Test.isRunningTest() && testAutoReviewFallbackCategory != null) {
            return testAutoReviewFallbackCategory;
        }

        String normalizedSource = String.isBlank(source) ? 'PORTAL' : source.trim().toUpperCase();
        Document_Intake_Config__mdt fallback;
        for (Document_Intake_Config__mdt config : Document_Intake_Config__mdt.getAll().values()) {
            if (config.Is_Active__c != true) {
                continue;
            }
            if (normalizedSource == config.Source__c) {
                return config.Auto_Review_Fallback_Category__c == true;
            }
            if (fallback == null && config.Source__c == 'PORTAL') {
                fallback = config;
            }
        }
        return fallback?.Auto_Review_Fallback_Category__c == true;
    }

    private static ReviewRow decodeRow(String encodedRow) {
        AIDocSplitFileRow.Request req = new AIDocSplitFileRow.Request();
        req.encodedRow = encodedRow;
        List<AIDocSplitFileRow.Response> decoded =
            AIDocSplitFileRow.execute(new List<AIDocSplitFileRow.Request>{ req });
        AIDocSplitFileRow.Response res = decoded.isEmpty() ? null : decoded[0];

        ReviewRow row = new ReviewRow();
        if (res == null) {
            return row;
        }
        row.fileContentDocumentId = parseId(res.fileContentDocumentId);
        row.documentCategoryId = parseId(res.documentCategoryId);
        row.categoryName = res.categoryName;
        row.expectedPartyName = res.partyName;
        row.partyType = res.partyType;
        return row;
    }

    private static Id parseId(String rawId) {
        if (String.isBlank(rawId)) {
            return null;
        }
        try {
            return (Id) rawId;
        } catch (Exception e) {
            return null;
        }
    }

    private static ReviewPayload runReviewFlow(ReviewRow row) {
        if (Test.isRunningTest()) {
            String stubJson = String.isBlank(testStubReviewJson) ? DEFAULT_REVIEW_JSON : testStubReviewJson;
            return new ReviewPayload(stubJson, stubJson);
        }

        try {
            Map<String, Object> inputs = new Map<String, Object>{
                'fileContentDocumentId' => String.valueOf(row.fileContentDocumentId),
                'categoryName' => row.categoryName,
                'expectedPartyName' => row.expectedPartyName,
                'partyType' => row.partyType
            };
            Flow.Interview interview = Flow.Interview.createInterview(REVIEW_FLOW_NAME, inputs);
            interview.start();
            String classificationJson = (String) interview.getVariableValue('verdictLine');
            String sanityJson = (String) interview.getVariableValue('sanityLine');
            return new ReviewPayload(
                String.isBlank(classificationJson) ? REVIEW_FAILED_JSON : classificationJson,
                String.isBlank(sanityJson) ? REVIEW_FAILED_JSON : sanityJson
            );
        } catch (Exception e) {
            return new ReviewPayload(REVIEW_FAILED_JSON, REVIEW_FAILED_JSON);
        }
    }

    private static Set<Id> normalizeIds(Set<Id> rawIds) {
        Set<Id> normalized = new Set<Id>();
        if (rawIds == null) {
            return normalized;
        }
        for (Id rawId : rawIds) {
            if (rawId != null) {
                normalized.add(rawId);
            }
        }
        return normalized;
    }

    private class ReviewRow {
        public Id fileContentDocumentId;
        public Id documentCategoryId;
        public String categoryName;
        public String expectedPartyName;
        public String partyType;

        public Boolean isReviewable() {
            return fileContentDocumentId != null && documentCategoryId != null;
        }
    }

    private class ReviewPayload {
        public String classificationJson;
        public String sanityJson;

        public ReviewPayload(String classificationJson, String sanityJson) {
            this.classificationJson = classificationJson;
            this.sanityJson = sanityJson;
        }
    }
}
